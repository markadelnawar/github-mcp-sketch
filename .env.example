# Same fine-grained PAT you used for the `github` MCP. The proxy uses it
# to forward calls to https://api.githubcopilot.com/mcp upstream.
GITHUB_PAT=ghp_...

# Optional. URL of the upstream MCP. Defaults to GitHub's hosted MCP.
UPSTREAM_MCP_URL=https://api.githubcopilot.com/mcp

# Optional. Maximum number of cached responses kept in memory for query_response.
# Older entries are evicted FIFO. Default 50.
CACHE_SIZE=50

# Optional. Path for the per-call micro metrics CSV. Default ./metrics.csv.
METRICS_CSV=./metrics.csv
